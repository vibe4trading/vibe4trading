# Database
# When using docker compose, Postgres is exposed on localhost:5433.
FCE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/fce

# API
FCE_LOG_LEVEL=info

# LLM (optional; if unset, the backend uses a deterministic stub model)
FCE_LLM_BASE_URL=
FCE_LLM_API_KEY=
FCE_LLM_MODEL=gpt-4o-mini
## Optional allowlist (comma-separated). When set, only these model keys are allowed.
## "stub" is always allowed.
FCE_LLM_MODEL_ALLOWLIST=
FCE_LLM_TIMEOUT_SECONDS=60
FCE_LLM_MAX_RETRIES=2

# LLM budgets / guardrails (0 disables that budget)
FCE_LLM_MAX_DECISION_CALLS_PER_RUN=500
FCE_LLM_MAX_SUMMARY_CALLS_PER_RUN=5
FCE_LLM_MAX_SENTIMENT_ITEM_SUMMARIES_PER_DATASET=200

# Jobs
FCE_JOB_HEARTBEAT_INTERVAL_SECONDS=10
FCE_JOB_STALE_AFTER_SECONDS=300
FCE_JOB_MAX_RUNNING_RUN_EXECUTE_REPLAY=1

# Worker (optional)
# Restrict a worker to a subset of job types. Useful when you run multiple workers.
# Examples:
# - dataset_import,run_execute_replay
# - run_execute_live
FCE_WORKER_JOB_TYPES=

# Auth (not wired yet; placeholders for future OIDC/JWKS)
FCE_OIDC_ISSUER=
FCE_OIDC_JWKS_URL=
FCE_OIDC_AUDIENCE=

# Vendor API placeholders (demo importer is currently used)
FCE_DEXSCREENER_BASE_URL=https://api.dexscreener.com
FCE_SENTIMENT_RSS_FEEDS=
