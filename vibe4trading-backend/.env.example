# Database
# When using docker compose, Postgres is exposed on localhost:5433.
V4T_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/v4t

# Redis (Celery broker + result backend)
V4T_REDIS_URL=redis://localhost:6379/0

# API
V4T_LOG_LEVEL=info

# LLM (optional; if unset, the backend uses a deterministic stub model)
V4T_LLM_BASE_URL=
V4T_LLM_API_KEY=
V4T_LLM_MODEL=gpt-5.3-codex-spark
## Optional allowlist (comma-separated). When set, only these model keys are allowed.
## "stub" is always allowed.
V4T_LLM_MODEL_ALLOWLIST=
V4T_LLM_TIMEOUT_SECONDS=60
V4T_LLM_MAX_RETRIES=2

# LLM budgets / guardrails (0 disables that budget)
V4T_LLM_MAX_DECISION_CALLS_PER_RUN=500
V4T_LLM_MAX_SUMMARY_CALLS_PER_RUN=5
V4T_LLM_MAX_SENTIMENT_ITEM_SUMMARIES_PER_DATASET=200

# Jobs
V4T_JOB_HEARTBEAT_INTERVAL_SECONDS=10
V4T_JOB_STALE_AFTER_SECONDS=300

# Runtime behavior (env-defined; not user-modifiable)
# Replay cadence
V4T_REPLAY_BASE_INTERVAL_SECONDS=3600
V4T_REPLAY_MIN_INTERVAL_SECONDS=60
V4T_REPLAY_PRICE_TICK_SECONDS=60

# Live cadence
V4T_LIVE_BASE_INTERVAL_SECONDS=60
V4T_LIVE_MIN_INTERVAL_SECONDS=30
V4T_LIVE_PRICE_TICK_SECONDS=5

# Prompt shaping
V4T_REPLAY_PROMPT_LOOKBACK_BARS=24
V4T_REPLAY_PROMPT_TIMEFRAME=1h
V4T_REPLAY_PROMPT_TIME_OFFSET_SECONDS=0
V4T_LIVE_PROMPT_LOOKBACK_BARS=60
V4T_LIVE_PROMPT_TIMEFRAME=1m
V4T_LIVE_PROMPT_TIME_OFFSET_SECONDS=0

# Execution economics
V4T_EXECUTION_FEE_BPS=10
V4T_EXECUTION_INITIAL_EQUITY_QUOTE=10000
V4T_EXECUTION_GROSS_LEVERAGE_CAP=1
V4T_EXECUTION_NET_EXPOSURE_CAP=1

# Celery
# Queue selection is done via `celery worker --queues=...` (see README / ARCHITECTURE).
V4T_CELERY_ALWAYS_EAGER=0

# Auth (not wired yet; placeholders for future OIDC/JWKS)
V4T_OIDC_ISSUER=
V4T_OIDC_JWKS_URL=
V4T_OIDC_AUDIENCE=

# Vendor API placeholders (demo importer is currently used)
V4T_DEXSCREENER_BASE_URL=https://api.dexscreener.com
V4T_SENTIMENT_RSS_FEEDS=

# RSS ingest hardening (optional)
V4T_SENTIMENT_RSS_TIMEOUT_SECONDS=10
V4T_SENTIMENT_RSS_MAX_BYTES=1000000
V4T_SENTIMENT_RSS_ALLOWED_SCHEMES=https,http
V4T_SENTIMENT_RSS_ALLOW_PRIVATE_HOSTS=0
V4T_SENTIMENT_RSS_ALLOWED_HOSTS=

# Arena
# Comma-separated UUIDs of pre-populated spot datasets.
V4T_ARENA_DATASET_IDS=
